# Copy to .env and fill in from your Supabase project (Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Server-side only — add to Vercel project env vars, NOT prefixed with VITE_
# Used by /api/scan-prescription for GPT-4 Vision prescription scanning
OPENAI_API_KEY=your-openai-api-key
