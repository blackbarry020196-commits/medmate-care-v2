# Copy to .env.local and fill in from your Supabase project (Settings → API)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Web Push — run: npx tsx scripts/generate-vapid.ts
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key

# Server-side only — add to Vercel project env vars, NOT prefixed with VITE_
OPENAI_API_KEY=your-openai-api-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:your@email.com
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
PUSH_API_SECRET=your-random-secret-for-cron-and-edge-function
